{
  "name": "desmos-graphing-calculator",
  "displayName": "Desmos Software Suite",
  "version": "0.4.1",
  "publisher": "evan-kolberg",
  "license": "MIT",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "desmos",
    "graphing",
    "calculator",
    "math",
    "3d",
    "geometry"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./src/extension.js",
  "icon": "./assets/supported_suite.jpg",
  "activationEvents": [
    "onCommand:extension.recoverData"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evan-kolberg/desmos-vscode-extension"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "desmosViewContainer",
          "title": "Desmos",
          "icon": "./assets/desmos-activity-bar.png"
        }
      ]
    },
    "views": {
      "desmosViewContainer": [
        {
          "id": "desmosCalcView",
          "name": "Desmos Calculators",
          "icon": "./assets/desmos-activity-bar.png"
        }
      ]
    },
    "commands": [
      {
        "command": "extension.openDesmos",
        "title": "Desmos: Graphing Calculator"
      },
      {
        "command": "extension.openDesmos3D",
        "title": "Desmos: 3D Calculator"
      },
      {
        "command": "extension.openDesmosScientific",
        "title": "Desmos: Scientific Calculator"
      },
      {
        "command": "extension.openDesmosFourFunction",
        "title": "Desmos: Four Function Calculator"
      },
      {
        "command": "extension.openDesmosGeometry",
        "title": "Desmos: Geometry Calculator"
      },
      {
        "command": "extension.togglePrerelease",
        "title": "Desmos: Toggle Prerelease Version"
      },
      {
        "command": "extension.openOnlineDesmos",
        "title": "Desmos: Open Online Desmos (Web)"
      },
      {
        "command": "extension.randomizeSeed",
        "title": "Desmos: Randomize Seed"
      },
      {
        "command": "extension.exportJson",
        "title": "Desmos: Export Data"
      },
      {
        "command": "extension.importJson",
        "title": "Desmos: Import Data"
      },
      {
        "command": "extension.clearUnsavedData",
        "title": "Desmos: Clear Recovery Items"
      }
    ]
  },
  "scripts": {
    "test": "mocha --require test/setup.js --timeout 10000"
  },
  "dependencies": {},
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "vscode": "^1.1.34"
  }
}
